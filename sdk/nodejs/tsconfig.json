{
    "compilerOptions": {
        "outDir": "bin",
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "declaration": true,
        "sourceMap": true,
        "stripInternal": true,
        "experimentalDecorators": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true
    },
    "files": [
        "config/index.ts",
        "config/vars.ts",
        "domain.ts",
        "domainVerification.ts",
        "index.ts",
        "provider.ts",
        "senderSignature.ts",
        "server.ts",
        "template.ts",
        "utilities.ts"
    ]
}
